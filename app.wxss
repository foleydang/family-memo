/* app.wxss - 全局样式 */

/* 主题色变量 */
page {
  --primary-color: #FF85A2;
  --primary-light: #FFB6C1;
  --primary-dark: #FF6B8A;
  --secondary-color: #FFD700;
  --success-color: #4CAF50;
  --warning-color: #FF9800;
  --danger-color: #F44336;
  --text-color: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --bg-color: #F8F8F8;
  --card-bg: #FFFFFF;
  --border-color: #EEEEEE;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--text-color);
  background-color: var(--bg-color);
  min-height: 100vh;
}

/* 全局容器 */
.container {
  padding: 24rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 133, 162, 0.1);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-color);
}

.card-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-dark));
  color: white;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 133, 162, 0.3);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: var(--card-bg);
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: 50rpx;
  padding: 22rpx 46rpx;
  font-size: 30rpx;
}

.btn-text {
  background: transparent;
  color: var(--primary-color);
  border: none;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
}

/* 输入框样式 */
.input-wrapper {
  background: var(--bg-color);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.input {
  font-size: 30rpx;
  color: var(--text-color);
}

/* 列表项样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.list-item:last-child {
  border-bottom: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-light);
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.tag-primary {
  background: var(--primary-light);
  color: var(--primary-dark);
}

.tag-success {
  background: #E8F5E9;
  color: var(--success-color);
}

.tag-warning {
  background: #FFF3E0;
  color: var(--warning-color);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 24rpx 0;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: var(--text-light);
}

/* 弹性布局辅助类 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-1 {
  flex: 1;
}

/* 间距辅助类 */
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
.ml-16 { margin-left: 16rpx; }
.mr-16 { margin-right: 16rpx; }
.p-24 { padding: 24rpx; }
.p-32 { padding: 32rpx; }

/* 文字辅助类 */
.text-center { text-align: center; }
.text-bold { font-weight: 600; }
.text-primary { color: var(--primary-color); }
.text-secondary { color: var(--text-secondary); }
.text-light { color: var(--text-light); }
.text-sm { font-size: 24rpx; }
.text-lg { font-size: 36rpx; }
.text-xl { font-size: 44rpx; }

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}

/* 心形装饰 */
.heart-decoration {
  position: relative;
}

.heart-decoration::before {
  content: '💕';
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  font-size: 32rpx;
  opacity: 0.6;
}