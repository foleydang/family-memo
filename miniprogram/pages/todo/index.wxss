/* pages/todo/index.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF85A2;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

/* Tab切换 */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 12rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 8rpx;
}

.tab.active {
  background: #FF85A2;
  color: #fff;
}

/* 待办列表 */
.todo-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.todo-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
  transition: background 0.2s;
}

.todo-item:last-child {
  border-bottom: none;
}

.todo-item.important {
  background: #fff9e6;
}

.todo-item.urgent {
  background: #fff1f0;
}

.todo-checkbox {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.checkbox-empty {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
}

.todo-content {
  flex: 1;
}

.todo-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.4;
}

.todo-title.done {
  color: #999;
  text-decoration: line-through;
}

.todo-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  line-height: 1.4;
}

.todo-meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
}

.priority-tag {
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  margin-right: 12rpx;
}

.priority-tag.important {
  background: #fff9e6;
  color: #fa8c16;
}

.priority-tag.urgent {
  background: #fff1f0;
  color: #f5222d;
}

.assignee {
  margin-right: 12rpx;
}

.todo-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-btn {
  font-size: 24rpx;
  color: #1890ff;
  padding: 8rpx 16rpx;
}

.action-btn.delete {
  color: #f5222d;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 26rpx;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.btn-clear {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.btn-add {
  padding: 16rpx 32rpx;
  background: #FF85A2;
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 80%;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #FF85A2;
  color: #fff;
  font-size: 30rpx;
}

.modal-close {
  font-size: 36rpx;
  padding: 8rpx;
}

.modal-body {
  padding: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.form-textarea {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 26rpx;
  min-height: 100rpx;
}

.priority-btns {
  display: flex;
  gap: 16rpx;
}

.priority-btn {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.priority-btn.active {
  background: #FF85A2;
  color: #fff;
}

.priority-btn.important.active {
  background: #fa8c16;
}

.priority-btn.urgent.active {
  background: #f5222d;
}

.picker-value {
  padding: 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.modal-footer {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
}

.btn-cancel {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.btn-confirm {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  background: #FF85A2;
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
}