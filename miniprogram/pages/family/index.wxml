<!--pages/family/index.wxml-->
<view class="container">
  <!-- 无家庭状态 -->
  <view wx:if="{{!familyInfo}}" class="no-family">
    <view class="no-family-icon">🏠</view>
    <view class="no-family-title">你还没有加入家庭</view>
    <view class="no-family-desc">创建或加入一个家庭，开始记录生活</view>
    <view class="action-btns">
      <view class="btn-primary" bindtap="showCreateModal">创建家庭</view>
      <view class="btn-secondary" bindtap="showJoinModal">加入家庭</view>
    </view>
  </view>

  <!-- 有家庭状态 -->
  <view wx:else class="family-info">
    <!-- 家庭基本信息 -->
    <view class="family-card">
      <view class="family-header">
        <view class="family-name">{{familyInfo.name}}</view>
        <view class="family-meta">
          <text>{{members.length}} 位成员</text>
          <text>创建于 {{familyInfo.created_at}}</text>
        </view>
      </view>
    </view>

    <!-- 成员列表 -->
    <view class="members-section">
      <view class="section-title">家庭成员</view>
      <view class="members-list">
        <block wx:for="{{members}}" wx:key="id">
          <view class="member-item">
            <image class="member-avatar" src="{{item.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
            <view class="member-info">
              <view class="member-name">{{item.name}}</view>
              <view class="member-role {{item.role}}">{{item.role === 'owner' ? '创建者' : item.role === 'admin' ? '管理员' : '成员'}}</view>
            </view>
            <view wx:if="{{familyInfo.owner_id === userInfo.id && item.id !== userInfo.id}}" class="member-action" bindtap="removeMember" data-id="{{item.id}}">
              移除
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- 邀请成员 -->
    <view class="invite-section">
      <view class="section-title">邀请成员</view>
      <view class="invite-card">
        <view wx:if="{{!inviteCode}}" class="invite-empty">
          <view class="btn-generate" bindtap="generateInviteCode">生成邀请码</view>
        </view>
        <view wx:else class="invite-code-box">
          <view class="invite-code">{{inviteCode}}</view>
          <view class="invite-actions">
            <view class="btn-copy" bindtap="copyInviteCode">复制</view>
            <view class="btn-share" bindtap="shareInvite">分享</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 快捷入口 -->
    <view class="quick-actions">
      <view class="section-title">快捷入口</view>
      <view class="action-grid">
        <view class="action-item" bindtap="goToShopping">
          <view class="action-icon">🛒</view>
          <view class="action-text">购物清单</view>
        </view>
        <view class="action-item" bindtap="goToTodo">
          <view class="action-icon">📋</view>
          <view class="action-text">家庭待办</view>
        </view>
        <view class="action-item" bindtap="goToSchedule">
          <view class="action-icon">📅</view>
          <view class="action-text">日程安排</view>
        </view>
      </view>
    </view>

    <!-- 退出家庭 -->
    <view class="leave-section">
      <view class="btn-leave" bindtap="leaveFamily">退出家庭</view>
    </view>
  </view>

  <!-- 创建家庭弹窗 -->
  <view wx:if="{{showModal && action === 'create'}}" class="modal-mask" bindtap="hideModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text>创建家庭</text>
        <view class="modal-close" bindtap="hideModal">×</view>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">家庭名称 *</text>
          <input class="form-input" placeholder="例如：温馨小家" value="{{createForm.name}}" bindinput="inputFamilyName" />
        </view>
      </view>
      <view class="modal-footer">
        <view class="btn-cancel" bindtap="hideModal">取消</view>
        <view class="btn-confirm" bindtap="createFamily">创建</view>
      </view>
    </view>
  </view>

  <!-- 加入家庭弹窗 -->
  <view wx:if="{{showModal && action === 'join'}}" class="modal-mask" bindtap="hideModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text>加入家庭</text>
        <view class="modal-close" bindtap="hideModal">×</view>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">邀请码 *</text>
          <input class="form-input" placeholder="请输入家庭邀请码" value="{{joinForm.code}}" bindinput="inputJoinCode" />
        </view>
        <view class="form-tip">
          <text>邀请码由家庭创建者提供</text>
        </view>
      </view>
      <view class="modal-footer">
        <view class="btn-cancel" bindtap="hideModal">取消</view>
        <view class="btn-confirm" bindtap="joinFamily">加入</view>
      </view>
    </view>
  </view>
</view>