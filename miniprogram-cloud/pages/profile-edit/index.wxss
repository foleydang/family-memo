/* pages/profile-edit/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
  box-sizing: border-box;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.avatar-section {
  display: flex;
  justify-content: center;
  padding: 20rpx 0;
}

.avatar-btn {
  background: transparent;
  padding: 0;
  margin: 0;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: normal;
}

.avatar-btn::after {
  display: none;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #FF85A2;
}

.avatar-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.input-section {
  display: flex;
  align-items: center;
}

.nickname-input {
  flex: 1;
  height: 80rpx;
  font-size: 32rpx;
  color: #333;
}

.tips {
  padding: 30rpx;
}

.tip-item {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 2;
}

.save-section {
  margin-top: 60rpx;
  padding: 0 30rpx;
}

.save-btn {
  width: 100%;
  background: linear-gradient(135deg, #FF85A2 0%, #FF6B8A 100%);
  color: #fff;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.save-btn::after {
  display: none;
}

.save-btn[disabled] {
  background: #ccc;
}
