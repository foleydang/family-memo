/* pages/index/index.wxss */

/* 加载中 */
.loading-card {
  background: linear-gradient(135deg, #FF85A2 0%, #FFB6C1 100%);
  color: white;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.loading-text {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 欢迎卡片 */
.welcome-card {
  background: linear-gradient(135deg, #FF85A2 0%, #FFB6C1 100%);
  color: white;
  position: relative;
  overflow: hidden;
}

.welcome-card::before {
  content: '💕';
  position: absolute;
  top: 20rpx;
  right: 30rpx;
  font-size: 80rpx;
  opacity: 0.3;
}

.welcome-header {
  display: flex;
  align-items: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 24rpx;
  background: #fff;
}

.welcome-text {
  flex: 1;
}

.greeting {
  font-size: 26rpx;
  opacity: 0.9;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  margin-top: 8rpx;
}

.welcome-footer {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.welcome-tips {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 分区标题 */
.section {
  margin-top: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #FF85A2;
}

/* 家庭卡片 */
.family-card {
  margin-top: 32rpx;
}

.family-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.family-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.family-name {
  font-size: 32rpx;
  font-weight: 600;
  flex: 1;
}

.family-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.family-members {
  display: flex;
  flex-wrap: wrap;
  padding-top: 16rpx;
}

.member {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
  margin-right: 20rpx;
  margin-bottom: 16rpx;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-bottom: 8rpx;
  border: 2rpx solid #FFB6C1;
  background: #f5f5f5;
}

.member-name {
  font-size: 22rpx;
  color: #666;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100rpx;
}

.add-member {
  justify-content: center;
}

.add-icon {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 50%;
  background: #FFE4EC;
  color: #FF85A2;
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

/* 快捷入口卡片 */
.quick-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-card {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.action-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.action-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.action-icon-box.shopping {
  background: linear-gradient(135deg, #FFE4EC 0%, #FFB6C1 100%);
}

.action-icon-box.todo {
  background: linear-gradient(135deg, #E8F5E9 0%, #A5D6A7 100%);
}

.action-icon-box.schedule {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFCC80 100%);
}

.action-icon {
  font-size: 36rpx;
}

.action-info {
  flex: 1;
}

.action-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.action-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 无家庭卡片 */
.no-family-card {
  margin-top: 32rpx;
  background: linear-gradient(135deg, #FFF5F7 0%, #FFE4EC 100%);
}

.no-family-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  text-align: center;
}

.no-family-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.no-family-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.no-family-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.no-family-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.create-btn {
  width: 100%;
  background: linear-gradient(135deg, #FF4D6A 0%, #FF85A2 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  height: 88rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.create-btn::after {
  display: none;
}

.join-btn {
  width: 100%;
  background: #fff;
  color: #FF4D6A;
  font-size: 30rpx;
  font-weight: 500;
  height: 88rpx;
  border: 2rpx solid #FF85A2;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.join-btn::after {
  display: none;
}

/* 登录提示 */
.login-prompt {
  text-align: center;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 32rpx;
}

.login-btn {
  background: linear-gradient(135deg, #FF4D6A 0%, #FF85A2 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  width: 400rpx;
  height: 88rpx;
  border-radius: 44rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn::after {
  display: none;
}

/* 订阅提醒按钮 */
.subscribe-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.subscribe-icon {
  font-size: 28rpx;
}

.subscribe-tip {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-left: 16rpx;
}
