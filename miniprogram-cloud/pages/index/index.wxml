<!--pages/index/index.wxml-->
<view class="container">
  <!-- 欢迎卡片 -->
  <view class="welcome-card card fade-in" wx:if="{{userInfo}}">
    <view class="welcome-header">
      <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="welcome-text">
        <view class="greeting">{{greeting}}，</view>
        <view class="nickname">{{userInfo.nickname || '亲爱的'}} 💕</view>
      </view>
    </view>
    <view class="welcome-footer">
      <text class="welcome-tips">{{todayStr}}</text>
    </view>
  </view>

  <!-- 未登录提示 -->
  <view class="login-prompt card" wx:else>
    <view class="empty-state">
      <text class="empty-icon">🏠</text>
      <text class="empty-text">欢迎使用家庭备忘录</text>
      <button class="btn-primary mt-24" bindtap="handleLogin">立即登录</button>
    </view>
  </view>

  <!-- 未加入家庭提示 -->
  <view class="card" wx:if="{{userInfo && !familyInfo}}">
    <view class="empty-state">
      <text class="empty-icon">👨👩👧👦</text>
      <text class="empty-text">还没有加入家庭哦</text>
      <view class="flex mt-24">
        <button class="btn-secondary mr-16" bindtap="handleJoinFamily">加入家庭</button>
        <button class="btn-primary" bindtap="handleCreateFamily">创建家庭</button>
      </view>
    </view>
  </view>

  <!-- 家庭信息 -->
  <view class="card family-card" wx:if="{{familyInfo}}">
    <view class="family-header">
      <text class="family-icon">🏠</text>
      <text class="family-name">{{familyInfo.name}}</text>
    </view>
    <view class="family-members" wx:if="{{members.length > 0}}">
      <view class="member" wx:for="{{members}}" wx:key="_id">
        <image class="member-avatar" src="{{item.avatar || '/images/default-avatar.png'}}"></image>
        <text class="member-name">{{item.nickname || '成员'}}</text>
      </view>
      <view class="member add-member" bindtap="goToFamily">
        <view class="add-icon">+</view>
        <text class="member-name">邀请</text>
      </view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="section" wx:if="{{familyInfo}}">
    <view class="section-title">快捷入口</view>
    <view class="quick-actions">
      <view class="action-card" bindtap="goToShopping">
        <view class="action-icon-box shopping">
          <text class="action-icon">🛒</text>
        </view>
        <view class="action-info">
          <view class="action-title">购物清单</view>
          <view class="action-desc">记录需要购买的物品</view>
        </view>
      </view>
      <view class="action-card" bindtap="goToTodo">
        <view class="action-icon-box todo">
          <text class="action-icon">✅</text>
        </view>
        <view class="action-info">
          <view class="action-title">待办事项</view>
          <view class="action-desc">管理家庭待办任务</view>
        </view>
      </view>
      <view class="action-card" bindtap="goToSchedule">
        <view class="action-icon-box schedule">
          <text class="action-icon">📅</text>
        </view>
        <view class="action-info">
          <view class="action-title">日程安排</view>
          <view class="action-desc">记录重要日程事件</view>
        </view>
      </view>
    </view>
  </view>
</view>
