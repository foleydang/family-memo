/* pages/feedback/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.type-group {
  display: flex;
  flex-wrap: wrap;
}

.type-item {
  display: flex;
  align-items: center;
  margin-right: 30rpx;
  margin-bottom: 10rpx;
  font-size: 28rpx;
}

.type-item radio {
  margin-right: 8rpx;
}

.content-input {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

.word-count {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  margin-top: 10rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  position: relative;
}

.image-item image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 36rpx;
  height: 36rpx;
  background: #FF6B6B;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1;
}

.add-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background: #f9f9f9;
  border: 2rpx dashed #ddd;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 48rpx;
  color: #ccc;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.contact-input {
  width: 100%;
  height: 70rpx;
  font-size: 28rpx;
  color: #333;
}

.submit-section {
  margin-top: 40rpx;
  padding: 0 30rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #FF85A2 0%, #FF6B8A 100%);
  color: #fff;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  border: none;
}

.submit-btn::after {
  display: none;
}

.submit-btn[disabled] {
  background: #ccc;
}

.history-section {
  margin-top: 30rpx;
}

.history-header {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #333;
}

.arrow {
  color: #999;
  font-size: 24rpx;
}

.history-list {
  background: #fff;
  border-radius: 16rpx;
  margin-top: 10rpx;
  overflow: hidden;
}

.history-item {
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-type {
  font-size: 24rpx;
  color: #FF85A2;
  margin-bottom: 8rpx;
}

.history-content {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-status {
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
}

.status-pending {
  color: #FFA500;
}

.status-processing {
  color: #1890ff;
}

.status-done {
  color: #52c41a;
}

.history-time {
  font-size: 24rpx;
  color: #999;
}

.history-empty {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  margin-top: 10rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
}
