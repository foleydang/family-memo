<!--pages/family/index.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 无家庭状态 -->
  <view class="no-family" wx:elif="{{!familyInfo}}">
    <text class="no-family-icon">🏠</text>
    <text class="no-family-title">你还没有加入家庭</text>
    <text class="no-family-desc">创建或加入一个家庭，开始记录生活</text>
    <view class="action-btns">
      <button class="btn-primary" bindtap="showCreateModal">创建家庭</button>
      <button class="btn-secondary" bindtap="showJoinModal">加入家庭</button>
    </view>
  </view>

  <!-- 有家庭状态 -->
  <view class="family-info" wx:else>
    <!-- 家庭卡片 -->
    <view class="family-card">
      <view class="family-header">
        <text class="family-name">{{familyInfo.name}}</text>
        <view class="family-meta">
          <text>{{members.length}} 位成员</text>
          <text wx:if="{{familyInfo.createTime}}">创建于 {{familyInfo.createTime}}</text>
        </view>
      </view>
    </view>

    <!-- 成员列表 -->
    <view class="members-section">
      <view class="section-title">家庭成员</view>
      <view class="members-list">
        <view class="member-item" wx:for="{{members}}" wx:key="_id">
          <image class="member-avatar" src="{{item._displayAvatar || '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="member-info">
            <view class="member-name">{{item.nickname || '成员'}}</view>
            <view class="member-role {{item.role}}">{{item.role === 'admin' ? '⭐ 管理员' : '成员'}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 邀请成员 -->
    <view class="invite-section">
      <view class="section-title">邀请成员</view>
      <view class="invite-card">
        <view wx:if="{{!familyInfo.inviteCode}}" class="invite-empty">
          <button class="btn-generate" bindtap="generateInviteCode">生成邀请码</button>
        </view>
        <view wx:else class="invite-code-box">
          <view class="invite-code">{{familyInfo.inviteCode}}</view>
          <view class="invite-actions">
            <button class="btn-copy" bindtap="copyInviteCode">复制</button>
          </view>
        </view>
      </view>
    </view>

    <!-- 退出家庭 -->
    <view class="leave-section">
      <button class="btn-leave" bindtap="leaveFamily">{{isAdmin ? '解散家庭' : '退出家庭'}}</button>
    </view>
  </view>

  <!-- 创建家庭弹窗 -->
  <view class="modal-mask" wx:if="{{showCreate}}" bindtap="hideCreateModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text>创建家庭</text>
        <view class="modal-close" bindtap="hideCreateModal">×</view>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">家庭名称 *</text>
          <input class="form-input" placeholder="例如：温馨小家" value="{{familyName}}" bindinput="onFamilyNameInput" />
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="hideCreateModal">取消</button>
        <button class="btn-confirm" bindtap="createFamily">创建</button>
      </view>
    </view>
  </view>

  <!-- 加入家庭弹窗 -->
  <view class="modal-mask" wx:if="{{showJoin}}" bindtap="hideJoinModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text>加入家庭</text>
        <view class="modal-close" bindtap="hideJoinModal">×</view>
      </view>
      <view class="modal-body">
        <view class="form-item">
          <text class="form-label">邀请码 *</text>
          <input class="form-input" placeholder="请输入家庭邀请码" value="{{inputCode}}" bindinput="onCodeInput" />
        </view>
        <view class="form-tip">
          <text>邀请码由家庭创建者提供</text>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="hideJoinModal">取消</button>
        <button class="btn-confirm" bindtap="joinFamily">加入</button>
      </view>
    </view>
  </view>
</view>
