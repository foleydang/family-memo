/* pages/family/index.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 无家庭状态 */
.no-family {
  text-align: center;
  padding: 100rpx 40rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-top: 60rpx;
}

.no-family-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.no-family-title {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.no-family-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.action-btns {
  display: flex;
  gap: 24rpx;
  justify-content: center;
}

.btn-primary {
  padding: 20rpx 40rpx;
  background: #FF85A2;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary {
  padding: 20rpx 40rpx;
  background: #fff;
  color: #FF85A2;
  border: 2rpx solid #FF85A2;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 家庭信息 */
.family-info {
  padding-bottom: 40rpx;
}

.family-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.family-header {
  display: flex;
  flex-direction: column;
}

.family-name {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.family-meta {
  display: flex;
  gap: 24rpx;
  font-size: 24rpx;
  color: #666;
}

/* 成员列表 */
.members-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #eee;
}

.members-list {
  padding: 16rpx 0;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eee;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #f5f5f5;
}

.member-info {
  flex: 1;
}

.member-name {
  font-size: 28rpx;
  color: #333;
}

.member-role {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.member-role.admin {
  color: #FF85A2;
}

/* 邀请成员 */
.invite-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.invite-card {
  padding: 20rpx;
}

.invite-empty {
  text-align: center;
}

.btn-generate {
  padding: 20rpx 40rpx;
  background: #FF85A2;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.invite-code-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.invite-code {
  font-size: 36rpx;
  color: #333;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.invite-actions {
  display: flex;
  gap: 16rpx;
}

.btn-copy, .btn-share {
  padding: 16rpx 28rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-copy {
  background: #f5f5f5;
  color: #666;
}

.btn-share {
  background: #FF85A2;
  color: #fff;
}

/* 退出家庭 */
.leave-section {
  text-align: center;
  padding: 40rpx 0;
}

.btn-leave {
  font-size: 28rpx;
  color: #f5222d;
  padding: 20rpx 48rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #f5222d;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 80%;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #FF85A2;
  color: #fff;
  font-size: 30rpx;
}

.modal-close {
  font-size: 36rpx;
  padding: 8rpx;
}

.modal-body {
  padding: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-tip {
  font-size: 22rpx;
  color: #999;
  padding-top: 8rpx;
}

.modal-footer {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
}

.btn-cancel {
  flex: 1;
  padding: 20rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-confirm {
  flex: 1;
  padding: 20rpx;
  background: #FF85A2;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
