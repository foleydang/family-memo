/* pages/todo/index.wxss */
.container {
  padding: 16rpx;
  padding-bottom: 120rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  background: linear-gradient(135deg, #FF85A2 0%, #FF6B8A 100%);
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 10rpx rgba(255,133,162,0.3);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 4rpx;
}

/* Tab切换 */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 8rpx;
}

.tab.active {
  background: #FF85A2;
  color: #fff;
}

/* 待办卡片 - 两行布局 */
.todo-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.todo-card {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 12rpx;
  padding: 14rpx 16rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
}

.todo-card.done {
  background: #f9f9f9;
}

.todo-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-top: 8rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.todo-dot.pending { background: #faad14; }
.todo-dot.doing { background: #1890ff; }
.todo-dot.done { background: #52c41a; }

.todo-body {
  flex: 1;
  min-width: 0;
}

/* 第一行：主信息 */
.todo-row-main {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
}

.priority-icon {
  font-size: 26rpx;
  margin-right: 6rpx;
  flex-shrink: 0;
}

.todo-title {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 8rpx;
}

.todo-title.done {
  color: #999;
  text-decoration: line-through;
}

.mini-avatar {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  margin-right: 4rpx;
  flex-shrink: 0;
  border: 1rpx solid #eee;
}

.assignee-name {
  font-size: 24rpx;
  color: #666;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.todo-time {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
  margin-right: 8rpx;
}

.action-btn.delete {
  width: 36rpx;
  height: 36rpx;
  border-radius: 8rpx;
  background: #fff5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #f5222d;
  flex-shrink: 0;
}

/* 第二行：备注 */
.todo-row-desc {
  margin-top: 6rpx;
  padding-left: 0;
}

.todo-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx;
  background: #fff;
  border-radius: 12rpx;
}

.empty-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.05);
}

.btn-clear {
  padding: 16rpx 28rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 10rpx;
  font-size: 26rpx;
}

.btn-add {
  padding: 16rpx 28rpx;
  background: #FF85A2;
  color: #fff;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 85%;
  background: #fff;
  border-radius: 16rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #FF85A2;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-close {
  font-size: 36rpx;
  padding: 4rpx;
  line-height: 1;
}

.modal-body {
  padding: 24rpx 20rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  width: 100%;
  height: 72rpx;
  padding: 0 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.priority-btns {
  display: flex;
  gap: 12rpx;
}

.priority-btn {
  flex: 1;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
}

.priority-btn.active {
  background: #FF85A2;
  color: #fff;
}

.priority-btn.important.active { background: #fa8c16; }
.priority-btn.urgent.active { background: #f5222d; }

.picker-value {
  height: 72rpx;
  padding: 0 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  font-size: 18rpx;
  color: #999;
}

.modal-footer {
  display: flex;
  padding: 20rpx;
  gap: 16rpx;
}

.btn-cancel {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 10rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-confirm {
  flex: 1;
  height: 72rpx;
  background: #FF85A2;
  color: #fff;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
