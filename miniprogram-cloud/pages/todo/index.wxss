/* pages/todo/index.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  background: linear-gradient(135deg, #FF85A2 0%, #FF6B8A 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 133, 162, 0.3);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* Tab切换 */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tab.active {
  background: #FF85A2;
  color: #fff;
  font-weight: 500;
}

/* 待办卡片列表 */
.todo-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.todo-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
}

.todo-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  border-radius: 6rpx 0 0 6rpx;
}

.todo-card.pending::before {
  background: #faad14;
}

.todo-card.doing::before {
  background: #1890ff;
}

.todo-card.done::before {
  background: #52c41a;
}

/* 顶部标签行 */
.todo-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-badge.pending {
  background: #fffbe6;
  color: #faad14;
}

.status-badge.doing {
  background: #e6f7ff;
  color: #1890ff;
}

.status-badge.done {
  background: #f6ffed;
  color: #52c41a;
}

.priority-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.priority-badge.important {
  background: #fff7e6;
  color: #fa8c16;
}

.priority-badge.urgent {
  background: #fff1f0;
  color: #f5222d;
}

/* 内容区 */
.todo-body {
  padding: 8rpx 0;
}

.todo-title {
  font-size: 32rpx;
  color: #333;
  line-height: 1.5;
  font-weight: 500;
}

.todo-title.done {
  color: #999;
  text-decoration: line-through;
}

.todo-desc {
  font-size: 26rpx;
  color: #666;
  margin-top: 8rpx;
  line-height: 1.4;
}

/* 底部信息行 */
.todo-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.assignee-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.assignee-info.empty {
  color: #999;
}

.assignee-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
}

.assignee-name {
  font-size: 26rpx;
  color: #333;
}

.no-assignee {
  font-size: 26rpx;
  color: #999;
}

.create-time {
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮 */
.todo-actions {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  display: flex;
  gap: 8rpx;
}

.action-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.action-btn.delete {
  background: #fff1f0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx;
  background: #fff;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.btn-clear {
  padding: 20rpx 32rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.btn-add {
  padding: 20rpx 32rpx;
  background: #FF85A2;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 85%;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #FF85A2;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

.modal-close {
  font-size: 40rpx;
  padding: 8rpx;
  line-height: 1;
}

.modal-body {
  padding: 32rpx 24rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.priority-btns {
  display: flex;
  gap: 16rpx;
}

.priority-btn {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.priority-btn.active {
  background: #FF85A2;
  color: #fff;
}

.priority-btn.important.active {
  background: #fa8c16;
}

.priority-btn.urgent.active {
  background: #f5222d;
}

.picker-value {
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
}

.modal-footer {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-confirm {
  flex: 1;
  height: 80rpx;
  background: #FF85A2;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
