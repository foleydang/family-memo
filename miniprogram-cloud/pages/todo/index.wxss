/* pages/todo/index.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  background: linear-gradient(135deg, #FF85A2 0%, #FF6B8A 100%);
  border-radius: 16rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255,133,162,0.3);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 4rpx;
}

/* Tab切换 */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tab.active {
  background: #FF85A2;
  color: #fff;
  font-weight: 500;
}

/* 待办卡片 */
.todo-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.todo-card {
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.todo-card.done {
  opacity: 0.7;
}

/* 左侧状态方块 */
.todo-status {
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 22rpx;
  flex-shrink: 0;
}

.todo-status.pending {
  background: #fffbe6;
  color: #faad14;
}

.todo-status.doing {
  background: #e6f7ff;
  color: #1890ff;
}

.todo-status.done {
  background: #f6ffed;
  color: #52c41a;
}

/* 内容区 */
.todo-content {
  flex: 1;
  min-width: 0;
}

/* 第一行：优先级 + 标题 */
.todo-row-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.priority-tag {
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}

.priority-tag.important {
  background: #fff7e6;
  color: #fa8c16;
}

.priority-tag.urgent {
  background: #fff1f0;
  color: #f5222d;
}

.todo-title {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.todo-title.done {
  color: #999;
  text-decoration: line-through;
}

/* 第二行：备注 */
.todo-row-desc {
  margin-top: 8rpx;
}

.todo-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
}

/* 第三行：指派人 + 时间 + 操作 */
.todo-row-meta {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
  gap: 12rpx;
}

.assignee-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.assignee-avatar {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 1rpx solid #eee;
}

.assignee-name {
  font-size: 26rpx;
  color: #666;
}

.no-assignee {
  font-size: 26rpx;
  color: #999;
}

.todo-time {
  font-size: 26rpx;
  color: #999;
  flex: 1;
}

.todo-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #1890ff;
}

.action-btn.delete {
  color: #f5222d;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
  background: #fff;
  border-radius: 14rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.05);
}

.btn-clear {
  padding: 18rpx 32rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.btn-add {
  padding: 18rpx 32rpx;
  background: #FF85A2;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 85%;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #FF85A2;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

.modal-close {
  font-size: 40rpx;
  padding: 4rpx;
}

.modal-body {
  padding: 28rpx 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.priority-btns {
  display: flex;
  gap: 16rpx;
}

.priority-btn {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.priority-btn.active {
  background: #FF85A2;
  color: #fff;
}

.priority-btn.important.active {
  background: #fa8c16;
}

.priority-btn.urgent.active {
  background: #f5222d;
}

.picker-value {
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
}

.modal-footer {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
}

.btn-cancel {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-confirm {
  flex: 1;
  height: 80rpx;
  background: #FF85A2;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
