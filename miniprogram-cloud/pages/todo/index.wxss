/* pages/todo/index.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  background: linear-gradient(135deg, #FF85A2 0%, #FF6B8A 100%);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 133, 162, 0.3);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* Tab切换 */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 10rpx;
  transition: all 0.2s;
}

.tab.active {
  background: #FF85A2;
  color: #fff;
  font-weight: 500;
}

/* 待办卡片列表 */
.todo-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.todo-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
}

.todo-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4rpx;
  border-radius: 4rpx 0 0 4rpx;
}

.todo-card.pending::before {
  background: #faad14;
}

.todo-card.doing::before {
  background: #1890ff;
}

.todo-card.done::before {
  background: #52c41a;
}

/* 左侧状态图标 */
.todo-status {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.todo-status.pending {
  background: #fffbe6;
}

.todo-status.doing {
  background: #e6f7ff;
}

.todo-status.done {
  background: #f6ffed;
}

/* 内容区 */
.todo-content {
  flex: 1;
  min-width: 0;
  overflow: hidden;
}

.todo-title-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.todo-title {
  font-size: 28rpx;
  color: #333;
  line-height: 1.3;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.todo-title.done {
  color: #999;
}

/* 标签 */
.priority-tag {
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  flex-shrink: 0;
}

.priority-tag.important {
  background: #fff7e6;
  color: #fa8c16;
}

.priority-tag.urgent {
  background: #fff1f0;
  color: #f5222d;
}

/* 底部信息行 */
.todo-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #999;
}

.assignee-info {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.assignee-avatar {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
}

/* 操作按钮 */
.todo-actions {
  display: flex;
  gap: 6rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.action-btn {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.action-btn.delete {
  background: #fff1f0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
  background: #fff;
  border-radius: 12rpx;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.btn-clear {
  padding: 16rpx 28rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 10rpx;
  font-size: 26rpx;
}

.btn-add {
  padding: 16rpx 28rpx;
  background: #FF85A2;
  color: #fff;
  border-radius: 10rpx;
  font-size: 26rpx;
  font-weight: 500;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 85%;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #FF85A2;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-close {
  font-size: 36rpx;
  padding: 4rpx;
  line-height: 1;
}

.modal-body {
  padding: 24rpx 20rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 72rpx;
  padding: 0 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.priority-btns {
  display: flex;
  gap: 12rpx;
}

.priority-btn {
  flex: 1;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}

.priority-btn.active {
  background: #FF85A2;
  color: #fff;
}

.priority-btn.important.active {
  background: #fa8c16;
}

.priority-btn.urgent.active {
  background: #f5222d;
}

.picker-value {
  height: 72rpx;
  padding: 0 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-arrow {
  font-size: 18rpx;
  color: #999;
}

.modal-footer {
  display: flex;
  padding: 20rpx;
  gap: 16rpx;
}

.btn-cancel {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 10rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-confirm {
  flex: 1;
  height: 72rpx;
  background: #FF85A2;
  color: #fff;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}
