/* pages/announcement/index.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 公告列表 */
.announcement-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.announcement-card {
  background: #fff;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.announcement-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.author-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 10rpx;
  border: 1rpx solid #eee;
}

.author-info {
  flex: 1;
}

.author-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.publish-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.delete-btn {
  width: 36rpx;
  height: 36rpx;
  background: #fff5f5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #f5222d;
}

.announcement-body {
  padding: 8rpx 0;
}

.announcement-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
  background: #fff;
  border-radius: 14rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-title {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #bbb;
}

/* 发布按钮 */
.publish-btn {
  position: fixed;
  bottom: 32rpx;
  left: 32rpx;
  right: 32rpx;
  background: linear-gradient(135deg, #FF85A2, #FFB6C1);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(255, 133, 162, 0.3);
}

.publish-icon {
  margin-right: 8rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 85%;
  background: #fff;
  border-radius: 16rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #FF85A2;
  color: #fff;
  font-size: 30rpx;
}

.modal-close {
  font-size: 36rpx;
}

.modal-body {
  padding: 24rpx 20rpx;
}

.form-item {
  margin-bottom: 16rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
  font-weight: 500;
}

.form-textarea {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 28rpx;
  min-height: 120rpx;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.modal-footer {
  display: flex;
  padding: 20rpx;
  gap: 16rpx;
}

.btn-cancel {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-confirm {
  flex: 1;
  height: 72rpx;
  background: #FF85A2;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
