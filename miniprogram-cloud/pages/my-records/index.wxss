/* pages/my-records/index.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* Tab 切换 */
.tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 12rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
}

.tab.active {
  background: #FF85A2;
  color: #fff;
  font-weight: bold;
}

/* 记录列表 */
.record-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-item.done {
  opacity: 0.6;
}

.record-item.important {
  background: #fff9e6;
  margin: 0 -20rpx;
  padding-left: 40rpx;
  padding-right: 40rpx;
}

.record-item.urgent {
  background: #fff1f0;
  margin: 0 -20rpx;
  padding-left: 40rpx;
  padding-right: 40rpx;
}

.record-checkbox {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.checkbox-empty {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
}

.record-content {
  flex: 1;
  min-width: 0;
}

.record-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-title.done-text {
  text-decoration: line-through;
  color: #999;
}

.record-meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
  color: #999;
}

.category-tag, .type-tag {
  padding: 4rpx 12rpx;
  background: #f5f5f5;
  border-radius: 4rpx;
  font-size: 20rpx;
}

.priority-tag {
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
}

.priority-tag.important {
  background: #fff9e6;
  color: #fa8c16;
}

.priority-tag.urgent {
  background: #fff1f0;
  color: #f5222d;
}

.status-tag {
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  background: #f5f5f5;
}

.status-tag.doing {
  background: #e6f7ff;
  color: #1890ff;
}

.status-tag.done {
  background: #f6ffed;
  color: #52c41a;
}

.time-text {
  font-size: 22rpx;
  color: #999;
}

.record-action {
  font-size: 24rpx;
  color: #f5222d;
  padding: 8rpx 16rpx;
  flex-shrink: 0;
}

/* 日程日期 - 修复重叠问题 */
.schedule-date-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 70rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  background: #FFF5F7;
  border-radius: 8rpx;
  padding: 8rpx 0;
}

.date-day {
  font-size: 26rpx;
  font-weight: bold;
  color: #FF85A2;
  line-height: 1.2;
}

.date-week {
  font-size: 20rpx;
  color: #999;
  line-height: 1.2;
  margin-top: 4rpx;
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 26rpx;
}

.no-family-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 26rpx;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 40rpx;
  color: #999;
}
