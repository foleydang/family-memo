<!--pages/export/index.wxml-->
<view class="container">
  <view class="header">
    <text class="title">数据导出</text>
    <text class="desc">将数据导出为文本，可粘贴到微信或备忘录</text>
  </view>

  <view class="export-list">
    <view class="export-item" wx:for="{{exportTypes}}" wx:key="id" bindtap="exportData" data-type="{{item.id}}">
      <view class="export-icon">{{item.icon}}</view>
      <view class="export-info">
        <view class="export-name">{{item.name}}</view>
        <view class="export-count">{{item.count}} 条记录</view>
      </view>
      <view class="export-arrow">导出 ›</view>
    </view>
  </view>

  <view class="export-all" bindtap="exportAll">
    <text>📦 导出全部数据</text>
  </view>

  <view class="tips">
    <text class="tips-title">💡 提示</text>
    <text>• 导出的数据将复制到剪贴板</text>
    <text>• 可粘贴到微信、备忘录等应用</text>
    <text>• 建议定期备份重要数据</text>
  </view>
</view>