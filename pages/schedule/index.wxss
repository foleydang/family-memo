/* pages/schedule/index.wxss */

/* 月份导航 */
.month-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 40rpx;
  margin-bottom: 20rpx;
}

.nav-btn {
  font-size: 40rpx;
  color: #FF85A2;
  padding: 8rpx 20rpx;
}

.month-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

/* 日历 */
.calendar {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.week-header {
  display: flex;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 16rpx;
}

.week-day {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

.calendar-body {
  display: flex;
  flex-wrap: wrap;
}

.day-cell {
  width: calc(100% / 7);
  height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.day-cell.empty {
  visibility: hidden;
}

.day-num {
  font-size: 26rpx;
  color: #333;
  line-height: 1;
}

.day-num.workday-text {
  color: #f5222d;
  font-size: 22rpx;
}

.day-cell.today .day-num {
  color: #FF85A2;
  font-weight: bold;
}

.day-cell.selected {
  background: #FFE4EC;
  border-radius: 8rpx;
}

.day-cell.selected .day-num {
  color: #FF85A2;
}

.schedule-dot {
  width: 8rpx;
  height: 8rpx;
  background: #FF85A2;
  border-radius: 50%;
  position: absolute;
  bottom: 4rpx;
}

/* 节假日标签 */
.holiday-label {
  font-size: 18rpx;
  line-height: 1;
  margin-top: 4rpx;
}

.holiday-label.holiday-text {
  color: #f5222d;
  font-weight: 500;
}

.holiday-label.term-text {
  color: #52c41a;
}

.day-cell.is-holiday .day-num {
  color: #f5222d;
}

.day-cell.is-workday {
  background: #f5f5f5;
  border-radius: 8rpx;
}

/* 选中日期日程 */
.day-schedules {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.date-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.date-holiday { color: #f5222d; font-size: 24rpx; font-weight: 500; margin-left: 8rpx; }
.date-term { color: #52c41a; font-size: 24rpx; margin-left: 8rpx; }
.date-festival { color: #FF85A2; font-size: 24rpx; margin-left: 8rpx; }

.add-btn {
  font-size: 24rpx;
  color: #FF85A2;
  padding: 8rpx 16rpx;
  background: #FFE4EC;
  border-radius: 8rpx;
}

.schedule-list {
  padding-top: 16rpx;
}

.schedule-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 12rpx;
  border-radius: 8rpx;
}

.schedule-item:last-child {
  border-bottom: none;
}

.schedule-item.type-birthday {
  background: #FFF0F6;
}

.schedule-item.type-anniversary {
  background: #E6F7FF;
}

.schedule-item.type-appointment {
  background: #F6FFED;
}

.schedule-item.type-meeting {
  background: #FFFBE6;
}

.schedule-item.type-trip {
  background: #FFF7E6;
}

.schedule-type {
  padding: 8rpx 16rpx;
  background: #FF85A2;
  color: #fff;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 16rpx;
}

.schedule-content {
  flex: 1;
}

.schedule-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.schedule-time {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.schedule-desc {
  font-size: 22rpx;
  color: #999;
}

.schedule-actions {
  display: flex;
  flex-direction: row;  /* 横向排列 */
  gap: 16rpx;
  align-items: center;
}

.action-btn {
  font-size: 24rpx;
  color: #1890ff;
  padding: 8rpx 20rpx;
  background: rgba(24, 144, 255, 0.1);
  border-radius: 8rpx;
}

.action-btn.delete {
  color: #f5222d;
  background: rgba(245, 34, 34, 0.1);
}

/* 空状态 */
.empty-tip {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 80%;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #FF85A2;
  color: #fff;
  font-size: 30rpx;
}

.modal-close {
  font-size: 36rpx;
  padding: 8rpx;
}

.modal-body {
  padding: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.form-textarea {
  width: 100%;
  padding: 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 26rpx;
  min-height: 100rpx;
}

.picker-value {
  padding: 16rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.modal-footer {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
}

.btn-cancel {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.btn-confirm {
  flex: 1;
  padding: 16rpx;
  text-align: center;
  background: #FF85A2;
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
}