/* pages/wish/index.wxss */

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #A78BFA, #C4B5FD);
  color: white;
  padding: 28rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(167, 139, 250, 0.3);
}

.add-icon { font-size: 36rpx; margin-right: 12rpx; }
.add-text { font-size: 30rpx; font-weight: 500; }

/* 筛选 */
.filter-tabs {
  display: flex;
  background: white;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab.active { background: #A78BFA; color: white; font-weight: 500; }

.category-scroll { white-space: nowrap; margin-bottom: 20rpx; padding: 8rpx 0; }

.category-item {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  background: white;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.category-item.active { background: #C4B5FD; color: #7C3AED; }

/* 心愿列表 */
.wish-list { background: white; border-radius: 24rpx; overflow: hidden; }

.wish-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: all 0.3s;
}

.wish-item:last-child { border-bottom: none; }

.wish-item.fulfilled { opacity: 0.6; }
.wish-item.fulfilled .wish-title { color: #999; }

.wish-content { flex: 1; min-width: 0; }

.wish-header { display: flex; align-items: center; margin-bottom: 8rpx; }

.wish-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.wish-badge {
  margin-left: 12rpx;
  padding: 4rpx 12rpx;
  background: #A78BFA;
  color: white;
  font-size: 20rpx;
  border-radius: 8rpx;
}

.wish-desc {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.wish-meta { display: flex; align-items: center; font-size: 24rpx; color: #999; }
.wish-category { margin-right: 16rpx; }
.wish-author { color: #A78BFA; }

.wish-actions { display: flex; align-items: center; margin-left: 16rpx; }

.action-btn { padding: 12rpx; font-size: 32rpx; }
.action-btn.fulfill { font-size: 36rpx; }
.action-btn.delete { color: #FF6B6B; }

/* 空状态 */
.empty-state { padding: 100rpx 0; text-align: center; }
.empty-icon { font-size: 100rpx; display: block; margin-bottom: 24rpx; }
.empty-text { font-size: 30rpx; color: #999; }
.empty-hint { font-size: 26rpx; color: #ccc; margin-top: 12rpx; }

.clear-btn {
  text-align: center;
  padding: 24rpx;
  color: #FF6B6B;
  font-size: 28rpx;
  margin-top: 24rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex; align-items: center; justify-content: center; z-index: 1000;
}

.modal-content { width: 90%; max-width: 600rpx; background: white; border-radius: 24rpx; overflow: hidden; }

.modal-header { display: flex; align-items: center; justify-content: space-between; padding: 32rpx; border-bottom: 1rpx solid #f5f5f5; }
.modal-title { font-size: 32rpx; font-weight: 600; }
.modal-close { font-size: 40rpx; color: #999; padding: 0 16rpx; }

.modal-body { padding: 32rpx; }
.form-item { margin-bottom: 28rpx; }
.form-label { display: block; font-size: 28rpx; color: #666; margin-bottom: 12rpx; }

.form-input {
  width: 100%; height: 80rpx; background: #f5f5f5;
  border-radius: 12rpx; padding: 0 24rpx; font-size: 28rpx; box-sizing: border-box;
}

.form-textarea {
  width: 100%; background: #f5f5f5;
  border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 28rpx; box-sizing: border-box;
  min-height: 80rpx;
}

.form-picker {
  height: 80rpx; background: #f5f5f5; border-radius: 12rpx;
  padding: 0 24rpx; font-size: 28rpx;
  display: flex; align-items: center; justify-content: space-between;
}

.picker-arrow { font-size: 20rpx; color: #999; }

.priority-check { display: flex; align-items: center; }
.priority-label { margin-left: 12rpx; font-size: 28rpx; color: #666; }

.check-box {
  width: 44rpx; height: 44rpx; border: 3rpx solid #ddd;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; color: white; transition: all 0.3s;
}

.check-box.checked { background: #A78BFA; border-color: #A78BFA; }

.modal-footer { display: flex; padding: 24rpx 32rpx 32rpx; gap: 24rpx; }
.modal-footer button { flex: 1; margin: 0; }

.btn-secondary { background: #f5f5f5; color: #666; border-radius: 40rpx; font-size: 28rpx; }
.btn-primary { background: linear-gradient(135deg, #A78BFA, #7C3AED); color: white; border-radius: 40rpx; font-size: 28rpx; }