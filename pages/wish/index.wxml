<!--pages/wish/index.wxml-->
<view class="container">
  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="showAddModal">
    <text class="add-icon">✨</text>
    <text class="add-text">发布心愿</text>
  </view>

  <!-- 状态筛选 -->
  <view class="filter-tabs">
    <view class="tab {{currentTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">
      未实现 ({{stats.pending}})
    </view>
    <view class="tab {{currentTab === 'fulfilled' ? 'active' : ''}}" bindtap="switchTab" data-tab="fulfilled">
      已实现 ({{stats.fulfilled}})
    </view>
  </view>

  <!-- 分类筛选 -->
  <scroll-view class="category-scroll" scroll-x>
    <view class="category-item {{currentCategory === 'all' ? 'active' : ''}}" bindtap="switchCategory" data-category="all">全部</view>
    <view class="category-item {{currentCategory === item.id ? 'active' : ''}}" 
          wx:for="{{categories}}" wx:key="id"
          bindtap="switchCategory" data-category="{{item.id}}">
      {{item.name}}
    </view>
  </scroll-view>

  <!-- 心愿列表 -->
  <view class="wish-list" wx:if="{{filteredList.length > 0}}">
    <view class="wish-item {{item.status === 'fulfilled' ? 'fulfilled' : ''}}" 
          wx:for="{{filteredList}}" wx:key="id">
      <view class="wish-content">
        <view class="wish-header">
          <text class="wish-title">{{item.title}}</text>
          <view class="wish-badge" wx:if="{{item.priority === 1}}">❗超想</view>
        </view>
        <view wx:if="{{item.description}}" class="wish-desc">{{item.description}}</view>
        <view class="wish-meta">
          <text class="wish-category">{{item.categoryName}}</text>
          <text class="wish-author">{{item.created_by_name}}</text>
        </view>
      </view>
      <view class="wish-actions">
        <view class="action-btn fulfill" catchtap="fulfillItem" data-id="{{item.id}}">
          {{item.status === 'fulfilled' ? '↩️' : '🌟'}}
        </view>
        <text class="action-btn" catchtap="editItem" data-item="{{item}}">✏️</text>
        <text class="action-btn delete" catchtap="deleteItem" data-id="{{item.id}}">🗑️</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <text class="empty-icon">🌟</text>
    <text class="empty-text">{{currentTab === 'pending' ? '暂无心愿' : '暂无已实现的心愿'}}</text>
    <text class="empty-hint" wx:if="{{currentTab === 'pending'}}">点击上方按钮发布心愿</text>
  </view>

  <!-- 清空已实现 -->
  <view class="clear-btn" wx:if="{{stats.fulfilled > 0 && currentTab === 'fulfilled'}}" bindtap="clearFulfilled">
    清空已实现心愿
  </view>
</view>

<!-- 弹窗 -->
<view class="modal-mask" wx:if="{{showModal}}" bindtap="hideModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">{{editMode ? '编辑心愿' : '发布心愿 ✨'}}</text>
      <text class="modal-close" bindtap="hideModal">×</text>
    </view>
    <view class="modal-body">
      <view class="form-item">
        <text class="form-label">心愿内容 *</text>
        <input class="form-input" placeholder="写下你的心愿" value="{{formData.title}}" bindinput="inputTitle" />
      </view>
      <view class="form-item">
        <text class="form-label">描述</text>
        <textarea class="form-textarea" placeholder="可选：描述一下为什么想要这个" value="{{formData.description}}" bindinput="inputDescription" maxlength="200" auto-height />
      </view>
      <view class="form-item">
        <text class="form-label">分类</text>
        <picker mode="selector" range="{{categories}}" range-key="name" value="{{categoryIndex}}" bindchange="pickCategory">
          <view class="form-picker">
            {{categories[categoryIndex].name}}
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>
      <view class="form-item">
        <view class="priority-check" bindtap="togglePriority">
          <view class="check-box {{formData.priority ? 'checked' : ''}}">
            <text wx:if="{{formData.priority}}">✓</text>
          </view>
          <text class="priority-label">标记为「超想」</text>
        </view>
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn-secondary" bindtap="hideModal">取消</button>
      <button class="btn-primary" bindtap="submitForm">{{editMode ? '保存' : '发布 ✨'}}</button>
    </view>
  </view>
</view>